# Application environment: dev | test | prod
APP_ENV=dev

# ------------------------------------------------------------------
# Local LLM (Ollama) — agent uses POST {OLLAMA}/api/chat
# Install: https://ollama.com — then `ollama pull llama3.2` (or your model).
# ------------------------------------------------------------------
# AGENTPV_OLLAMA_BASE_URL=http://localhost:11434
# AGENTPV_OLLAMA_MODEL=llama3.2

# ------------------------------------------------------------------
# Optional overrides (Pydantic: AGENTPV_* maps to configs/settings.py)
# ------------------------------------------------------------------

# AGENTPV_LLM_BACKEND=mock
# AGENTPV_LLM_BACKEND=ollama
# AGENTPV_LOG_LEVEL=DEBUG
# AGENTPV_LOG_FORMAT=text
# AGENTPV_RAG_RETRIEVAL=auto
# AGENTPV_REACT_MAX_ITERATIONS=5
