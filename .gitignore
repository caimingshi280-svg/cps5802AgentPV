# Python
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
.pytest_cache/
.ruff_cache/
.mypy_cache/
htmlcov/
.coverage
.coverage.*
*.cover

# Virtual environments
.venv/
venv/
ENV/

# Environment & secrets
.env
.env.local
.env.*.local

# OS
.DS_Store
Thumbs.db
Desktop.ini

# IDEs / editors
.idea/
.vscode/
*.swp
*.swo
*~

# Installers & large local binaries (never commit)
*.exe
*.msi
*.dmg
*.pkg

# Cursor local (optional rules file is tracked at repo root)
.cursor/

# --- Project: regenerated data ---
data/raw/*
data/processed/*
data/splits/*
data/_*/
data/version.txt
!data/raw/.gitkeep
!data/processed/.gitkeep
!data/splits/.gitkeep

# Orchestrator / dashboard runtime event logs
data/orchestrator/*
!data/orchestrator/.gitkeep

# --- Project: models & vector store ---
quantization/artifacts/*
!quantization/artifacts/.gitkeep

rag/knowledge_base/chroma_db/*
!rag/knowledge_base/chroma_db/.gitkeep

# --- Project: eval raw JSON (regenerated; summaries live in reports/*.md) ---
agent_eval/results/*
!agent_eval/results/.gitkeep
agent_eval/results/*.log

# --- Project: figures (regenerated by report scripts) ---
reports/figures/*
!reports/figures/.gitkeep
reports/robustness/**/figures/*
!reports/robustness/**/figures/.gitkeep

# HTML export of final report (regenerate from final_report.md)
reports/final_report.html

# Stale one-off report snapshots (canonical: reports/agent_eval.md)
reports/agent_eval_last_run*.md

# Draft PPTX variants (keep canonical reports/AgentPV_Final_Presentation.pptx if committed)
reports/AgentPV_Final_Presentation_v*.pptx

# Docker runtime
*.pid

# Jupyter
.ipynb_checkpoints/

# Logs
*.log
